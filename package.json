{
  "name": "elysia-starter-template",
  "version": "1.0.50",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "bun run --watch src/main.ts",
    "build": "bunx tsc --noEmit && bun build --compile --minify-whitespace --minify-syntax --target bun --outfile ./.output/server ./src/main.ts",
    "start": "./.output/server",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.8",
    "@elysiajs/openapi": "^1.4.14",
    "better-auth": "^1.5.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "elysia": "latest",
    "elysia-rate-limit": "^4.5.0",
    "logixlysia": "^6.2.0",
    "nanoid": "^5.1.6",
    "nodemailer": "^8.0.1",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.56.1"
  },
  "module": "src/index.js"
}